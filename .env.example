# ══════════════════════════════════════════════════════════════════════
# VLSI Interview Platform V2 — Environment Variables
#
# Usage:
#   cp .env.example .env
#   Edit .env with real values
#   NEVER commit .env to version control
#
# Generate JWT_SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_hex(64))"
# ══════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=vlsi
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=vlsi_interview

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ── JWT Authentication ─────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_run_python3_minus_c_import_secrets_print_secrets.token_hex_64
JWT_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Optional providers (leave blank to use OpenAI fallbacks) ──────────────────
MISTRAL_API_KEY=
INWORLD_API_KEY=

# ── Frontend build-time variables ─────────────────────────────────────────────
# Leave blank for same-origin deployment (recommended for nginx setup).
# The frontend derives WS URL from window.location.host when VITE_WS_URL is blank.
VITE_API_URL=
VITE_WS_URL=
